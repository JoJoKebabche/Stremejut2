  m_text: "\u0422\u0438 \u0441\u0438 \u0433\u0435\u0440\u043E\u0439 \u0441 \u0432\u0435\u043B\u0438\u043A\u0438
    \u043C\u0435\u0447\u0442\u0438! \n\u041F\u044A\u0442\u0443\u0432\u0430\u0439
    \u0438\u0437 \u0437\u0430\u0431\u0440\u0430\u0432\u0435\u043D\u0438 \u043F\u043B\u0430\u043D\u0438\u043D\u0438!\nC\u044A\u0431\u0438\u0440\u0430\u0439
    \u0434\u0438\u0430\u043C\u0430\u043D\u0442\u0438 \u0438 \u0447\u0435\u0440\u0435\u0448\u0438,
    \u043A\u043E\u0438\u0442\u043E \u0434\u0430 \u0442\u0438 \u043F\u043E\u043C\u0430\u0433\u0430\u0442!\n\u041D\u0430\u043C\u0435\u0440\u0438
    \u0444\u043B\u0430\u0433\u0430 \u0437\u0430 \u0434\u0430 \u043F\u043E\u0431\u0435\u0434\u0438\u0448
    \u043D\u0438\u0432\u043E\u0442\u043E!\n\n\u0417\u0430\u043F\u043E\u0437\u043D\u0430\u0439
    \u0441\u0435 \u0441 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0442\u0435
    \u043D\u0430 \u0438\u0433\u0440\u0430\u0442\u0430 \u0432 \u0441\u0435\u043A\u0446\u0438\u044F
    \u041E\u043F\u0446\u0438\u0438."
